12:["$","section",null,{"id":"about","className":"py-24 bg-background","children":["$","div",null,{"className":"container mx-auto px-6","children":["$","div",null,{"className":"grid lg:grid-cols-2 gap-12 items-center","children":[["$","div",null,{"className":"relative aspect-[4/5] rounded-lg overflow-hidden","children":["$","$L7",null,{"src":"/images/artist-about.jpg","alt":"Kofi Asante portrait","fill":true,"className":"object-cover"}]}],["$","div",null,{"children":[["$","p",null,{"className":"text-primary tracking-[0.3em] text-sm mb-4","children":"THE ARTIST"}],["$","h2",null,{"className":"text-4xl md:text-5xl font-bold tracking-tight mb-8","children":"About Tiki ziki"}],["$","div",null,{"className":"space-y-6 text-muted-foreground text-lg leading-relaxed","children":[["$","p",null,{"children":"Tiki Ziki is an emerging Afropop and Afrobeat artist from Mombasa, Kenya. His music blends contemporary African rhythms with melodic storytelling, creating a sound influenced by modern Afrobeats while maintaining a distinct coastal East African identity Through his releases, he focuses on themes of ambition, relationships, and everyday life experiences."}],["$","p",null,{"children":"Over time, Tiki Ziki has developed a growing catalog of songs distributed on digital streaming platforms, building a presence among listeners interested in Afropop and Afrobeat music. His work combines catchy melodies with rhythmic production,positioning him within the new generation of independent African artists working to expand their audience both locally and internationally."}],["$","p",null,{"children":"Working with Top Sound Music Label, Tiki Ziki continues to develop new projects and collaborations aimed at reaching wider global audiences. His music strategy includes digital distribution, online promotion, and performance opportunities designed to strengthen his presence within the evolving Afrobeats scene."}]]}],["$","div",null,{"className":"grid grid-cols-2 md:grid-cols-4 gap-6 mt-12 p