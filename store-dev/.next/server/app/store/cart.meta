{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/store/layout,_N_T_/store/cart/layout,_N_T_/store/cart/page,_N_T_/store/cart"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/store/cart/__PAGE__",
    "/store/cart",
    "/store",
    "/_index",
    "/_head"
  ]
}